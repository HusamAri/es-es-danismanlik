---
interface QA {
  q: string;
  a: string;
}

interface Props {
  items: QA[];
  startOpen?: number;
}

const { items, startOpen = 0 } = Astro.props;
---

<div class="mx-auto max-w-3xl divide-y divide-cream-300 rounded-2xl border border-cream-300 bg-white">
  {
    items.map((item, idx) => (
      <details
        class="group p-5 [&_summary::-webkit-details-marker]:hidden"
        open={idx === startOpen}
      >
        <summary class="flex cursor-pointer items-center justify-between gap-4 text-left text-base font-medium text-navy-800">
          <span>{item.q}</span>
          <span
            aria-hidden="true"
            class="grid h-7 w-7 shrink-0 place-items-center rounded-full border border-cream-300 text-gold-500 transition-transform group-open:rotate-45"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M7 1.5v11M1.5 7h11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
            </svg>
          </span>
        </summary>
        <div class="mt-3 text-sm leading-relaxed text-muted">
          <p>{item.a}</p>
        </div>
      </details>
    ))
  }
</div>
