---
interface QA {
  q: string;
  a: string;
}

interface Props {
  items: QA[];
  startOpen?: number;
}

const { items, startOpen = 0 } = Astro.props;
---

<div class="mx-auto max-w-3xl space-y-4">
  {
    items.map((item, idx) => (
      <details
        class="group nm-raised bg-paper px-6 py-5 [&_summary::-webkit-details-marker]:hidden"
        open={idx === startOpen}
      >
        <summary class="flex cursor-pointer items-center justify-between gap-6 text-left">
          <span class="text-base text-navy-800" style="font-family: var(--font-display); font-weight: 500; letter-spacing: -0.01em;">{item.q}</span>
          <span
            aria-hidden="true"
            class="grid h-9 w-9 shrink-0 place-items-center rounded-full text-gold-ink nm-raised transition-transform group-open:rotate-45"
          >
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none">
              <path d="M7 1.5v11M1.5 7h11" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            </svg>
          </span>
        </summary>
        <div class="mt-4 pr-2 text-sm text-ink-secondary" style="line-height: 1.75;">
          <p>{item.a}</p>
        </div>
      </details>
    ))
  }
</div>
