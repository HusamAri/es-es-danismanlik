---
import { siteConfig } from "~/lib/siteConfig";
import { link } from "~/lib/url";

const accessKey = siteConfig.forms.web3formsAccessKey;

const fieldClass =
  "mt-2 w-full border border-[var(--border-soft)] bg-paper px-4 py-3 text-sm text-ink focus:border-navy-800 focus:outline-none";
const labelClass = "block";
const labelTextClass = "text-xs uppercase tracking-[0.22em] text-ink-secondary";
---

<form id="contact-form" class="grid gap-6" novalidate>
  <input type="hidden" name="access_key" value={accessKey} />
  <input type="hidden" name="subject" value="Randevu Talebi — ES-ES Danışmanlık" />
  <input type="hidden" name="from_name" value="ES-ES Danışmanlık Web Sitesi" />
  <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

  <div class="grid gap-6 md:grid-cols-2">
    <label class={labelClass}>
      <span class={labelTextClass}>Ad Soyad <span aria-hidden="true">*</span></span>
      <input type="text" name="ad_soyad" required autocomplete="name" class={fieldClass} />
    </label>
    <label class={labelClass}>
      <span class={labelTextClass}>E-posta <span aria-hidden="true">*</span></span>
      <input type="email" name="email" required autocomplete="email" class={fieldClass} />
    </label>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    <label class={labelClass}>
      <span class={labelTextClass}>Telefon</span>
      <input type="tel" name="telefon" autocomplete="tel" inputmode="tel" class={fieldClass} />
    </label>
    <label class={labelClass}>
      <span class={labelTextClass}>Konu</span>
      <select name="konu" id="konu-select" class={fieldClass}>
        <option value="genel">Genel Bilgi</option>
        <option value="bireysel">Bireysel Mentörlük</option>
        <option value="grup">Grup Programları</option>
        <option value="kurumsal">Kurumsal Danışmanlık</option>
      </select>
    </label>
  </div>

  <label class={labelClass}>
    <span class={labelTextClass}>Mesajınız <span aria-hidden="true">*</span></span>
    <textarea name="mesaj" rows="5" required class={fieldClass}></textarea>
  </label>

  <label class="flex items-start gap-3 border border-[var(--border-soft)] bg-paper p-4 text-sm">
    <input type="checkbox" name="kvkk_onay" required class="mt-1 h-5 w-5 shrink-0 accent-[var(--color-gold-500)]" />
    <span class="text-ink-secondary" style="line-height: 1.6;">
      <a href={link("/kvkk-aydinlatma")} class="underline decoration-gold-500 underline-offset-4 text-navy-800">KVKK Aydınlatma Metni</a>'ni
      okudum; kişisel verilerimin formdaki amaç doğrultusunda işlenmesine
      <em>açık rızam ile</em> onay veriyorum.
    </span>
  </label>

  <div class="flex flex-wrap items-center justify-between gap-4">
    <button type="submit" id="form-submit" class="btn btn-primary">Randevu Talebi Gönder</button>
    <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
  </div>
</form>

<script is:inline>
  (function () {
    var form = document.getElementById("contact-form");
    if (!form) return;
    var statusEl = document.getElementById("form-status");
    var btn = document.getElementById("form-submit");

    // Konu ön-seçimi (?konu=...)
    var params = new URLSearchParams(window.location.search);
    var konu = params.get("konu");
    var select = document.getElementById("konu-select");
    if (konu && select) {
      var valid = Array.prototype.map.call(select.options, function (o) { return o.value; });
      if (valid.indexOf(konu) >= 0) select.value = konu;
    }

    function setStatus(msg, kind) {
      if (!statusEl) return;
      statusEl.textContent = msg;
      statusEl.style.color =
        kind === "ok" ? "#3d4a3f" : kind === "err" ? "#9f2f2d" : "#4a5267";
    }

    form.addEventListener("submit", function (e) {
      e.preventDefault();

      var bot = form.querySelector('input[name="botcheck"]');
      if (bot && bot.checked) return; // honeypot

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      var data = Object.fromEntries(new FormData(form).entries());
      btn.disabled = true;
      btn.style.opacity = "0.6";
      setStatus("Gönderiliyor…", "info");

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify(data),
      })
        .then(function (r) { return r.json(); })
        .then(function (res) {
          if (res && res.success) {
            form.reset();
            setStatus("Talebiniz iletildi. En kısa sürede dönüş yapacağız.", "ok");
          } else {
            setStatus(
              "Gönderilemedi. Lütfen telefon veya e-posta ile ulaşın.",
              "err"
            );
          }
        })
        .catch(function () {
          setStatus("Bağlantı hatası. Lütfen telefon veya e-posta ile ulaşın.", "err");
        })
        .finally(function () {
          btn.disabled = false;
          btn.style.opacity = "1";
        });
    });
  })();
</script>
