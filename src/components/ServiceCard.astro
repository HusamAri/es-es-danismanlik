---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: "user" | "users" | "building" | "compass";
}

const { title, description, href, icon = "user" } = Astro.props;

const iconPath: Record<string, string> = {
  user: "M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm0 2c-4.42 0-8 2.69-8 6v2h16v-2c0-3.31-3.58-6-8-6Z",
  users: "M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm8 1a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-8 2c-4.42 0-8 2.24-8 5v2h12v-2c0-1.27.45-2.43 1.21-3.33A11.7 11.7 0 0 0 9 14Zm8 0c-1.32 0-2.5.27-3.5.74A4.99 4.99 0 0 1 16 19v2h7v-2c0-2.76-2.69-5-6-5Z",
  building: "M3 21V5l9-2v18H3Zm11 0V9l7 2v10h-7ZM6 9h3v2H6V9Zm0 4h3v2H6v-2Zm0 4h3v2H6v-2Zm10-4h3v2h-3v-2Zm0 4h3v2h-3v-2Z",
  compass: "M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm3.5 6.5L13 13l-4.5 2.5L11 11Z",
};
---

<article class="card group flex h-full flex-col">
  <div
    class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-navy-800 text-gold-300"
    aria-hidden="true"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
      <path d={iconPath[icon]} />
    </svg>
  </div>
  <h3 class="text-xl">{title}</h3>
  <hr class="gold-divider" />
  <p class="text-sm text-muted leading-relaxed">{description}</p>
  <a
    href={href}
    class="mt-6 inline-flex items-center gap-1 text-sm font-medium text-navy-700 transition-colors hover:text-gold-600"
  >
    Detaylı Bilgi
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
  </a>
</article>
