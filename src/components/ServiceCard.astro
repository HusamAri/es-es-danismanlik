---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  description: string;
  href: string;
  index?: string;
  icon?: "bireysel" | "grup" | "kurumsal";
}

const { title, description, href, index, icon } = Astro.props;
---

<article
  class="svc-card group relative flex h-full flex-col border-l border-[var(--border-soft)] pl-7 transition-colors hover:border-gold-500"
  data-reveal
>
  <div class="flex items-center justify-between">
    {
      icon && (
        <span class="text-gold-ink transition-transform duration-500 group-hover:-translate-y-1">
          <Icon name={icon} size={40} />
        </span>
      )
    }
    {index && (
      <span
        class="font-[var(--font-italic)] italic text-xs text-gold-ink tracking-wider"
        aria-hidden="true"
      >
        {index}
      </span>
    )}
  </div>
  <h3 class="mt-5 text-xl text-navy-800">{title}</h3>
  <hr class="gold-divider" />
  <p class="text-sm text-ink-secondary" style="line-height: 1.75;">{description}</p>
  <a
    href={href}
    class="mt-8 inline-flex min-h-11 items-center gap-2 py-2 text-xs uppercase tracking-[0.22em] text-navy-800 transition-colors hover:text-gold-ink"
    style="font-weight: 500;"
  >
    Detayı oku
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
  </a>
</article>
