---
interface Props {
  title: string;
  description: string;
  href: string;
  index?: string;
}

const { title, description, href, index } = Astro.props;
---

<article
  class="svc-card group relative flex h-full flex-col border-l border-[var(--border-soft)] pl-7 transition-colors hover:border-gold-500"
  data-reveal
>
  {index && (
    <span
      class="font-[var(--font-italic)] italic text-xs text-gold-500 tracking-wider"
      aria-hidden="true"
    >
      {index}
    </span>
  )}
  <h3 class="mt-3 text-xl text-navy-800">{title}</h3>
  <hr class="gold-divider" />
  <p class="text-sm text-ink-secondary" style="line-height: 1.75;">{description}</p>
  <a
    href={href}
    class="mt-8 inline-flex min-h-11 items-center gap-2 py-2 text-xs uppercase tracking-[0.22em] text-navy-800 transition-colors hover:text-gold-500"
    style="font-weight: 500;"
  >
    Detayı oku
    <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
  </a>
</article>
