---
interface Props {
  eyebrow?: string;
  title: string;
  italicTail?: string;
  description?: string;
  align?: "left" | "center";
  kinetic?: boolean;
}

const { eyebrow, title, italicTail, description, align = "center", kinetic = true } = Astro.props;
const alignClass = align === "center" ? "text-center mx-auto" : "text-left";
---

<div class={`max-w-2xl ${alignClass}`}>
  {eyebrow && <span class="eyebrow" data-reveal="fade">{eyebrow}</span>}

  {
    kinetic ? (
      <h2 class="kinetic mt-3">
        <span class="k-line">{title}</span>
        {italicTail && <span class="k-line accent">{italicTail}</span>}
      </h2>
    ) : (
      <h2 class="mt-3" data-reveal>
        {title}
        {italicTail && (
          <>
            <br />
            <span class="accent">{italicTail}</span>
          </>
        )}
      </h2>
    )
  }

  <hr
    class={`gold-divider draw-line ${align === "center" ? "gold-divider-center" : ""}`}
    data-reveal="fade"
    style="--reveal-delay: 250ms;"
  />

  {
    description && (
      <p
        class="text-lead text-ink-secondary"
        style="line-height: 1.7; --reveal-delay: 350ms;"
        data-reveal
      >
        {description}
      </p>
    )
  }
</div>
