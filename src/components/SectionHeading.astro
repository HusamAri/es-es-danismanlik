---
interface Props {
  eyebrow?: string;
  title: string;
  italicTail?: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, italicTail, description, align = "center" } = Astro.props;
const alignClass = align === "center" ? "text-center mx-auto" : "text-left";
---

<div class={`max-w-2xl ${alignClass}`}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="mt-3">
    {title}
    {italicTail && <><br /><span class="accent">{italicTail}</span></>}
  </h2>
  {align === "center" && <hr class="gold-divider gold-divider-center" />}
  {align === "left" && <hr class="gold-divider" />}
  {description && <p class="text-lead text-ink-secondary" style="line-height: 1.7;">{description}</p>}
</div>
