---
import { siteConfig } from "~/lib/siteConfig";
const phone = siteConfig.contact.whatsapp.replace(/^\+/, "");
const text = encodeURIComponent(
  "Merhaba, ES-ES Danışmanlık hizmetleri hakkında bilgi almak istiyorum."
);
---

<a
  href={`https://wa.me/${phone}?text=${text}`}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="WhatsApp üzerinden iletişime geçin"
  class="fixed bottom-5 right-5 z-40 inline-flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-[0_8px_24px_-4px_rgba(37,211,102,0.4)] transition-transform hover:scale-105"
>
  <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M.057 24l1.687-6.163A11.867 11.867 0 0 1 .029 11.945C.027 5.355 5.4.027 11.99.027c3.198 0 6.2 1.243 8.457 3.498a11.821 11.821 0 0 1 3.5 8.443c-.003 6.59-5.376 11.91-11.97 11.91a11.953 11.953 0 0 1-5.71-1.452L.057 24zm6.598-3.804c1.731.998 3.276 1.595 5.34 1.595 5.488 0 9.957-4.464 9.96-9.954.002-5.51-4.448-9.97-9.951-9.972-5.484 0-9.954 4.464-9.957 9.95 0 2.184.643 3.825 1.717 5.55l-.987 3.604 3.878-1.273zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.149-.173.198-.297.297-.495.099-.198.05-.371-.025-.52-.074-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.371s-1.04 1.016-1.04 2.479c0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.71.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
