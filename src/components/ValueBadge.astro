---
interface Props {
  title: string;
  description: string;
  number?: string;
}

const { title, description, number = "—" } = Astro.props;
---

<div class="flex flex-col items-start text-left" data-reveal>
  <span
    class="font-[var(--font-italic)] italic text-2xl text-gold-500 leading-none"
    aria-hidden="true"
  >
    {number}
  </span>
  <h4 class="mt-4 text-base text-navy-800">{title}</h4>
  <p class="mt-2 text-sm text-ink-secondary" style="line-height: 1.7;">{description}</p>
</div>
