---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  description: string;
  number?: string;
  icon?: "hedef" | "takip" | "odak" | "strateji";
}

const { title, description, number = "—", icon } = Astro.props;
---

<div class="card flex h-full flex-col items-start text-left" data-reveal>
  <div class="flex items-center gap-3">
    {
      icon && (
        <span class="grid h-11 w-11 place-items-center rounded-full text-gold-ink nm-inset">
          <Icon name={icon} size={24} />
        </span>
      )
    }
    <span
      class="font-[var(--font-italic)] italic text-xl text-gold-ink leading-none"
      aria-hidden="true"
    >
      {number}
    </span>
  </div>
  <h4 class="mt-4 text-base text-navy-800">{title}</h4>
  <p class="mt-2 text-sm text-ink-secondary" style="line-height: 1.7;">{description}</p>
</div>
