---
interface Props {
  title: string;
  description: string;
  icon: "target" | "calendar" | "spark" | "check";
}

const { title, description, icon } = Astro.props;

const paths: Record<string, string> = {
  target:
    "M12 22a10 10 0 1 1 10-10 10 10 0 0 1-10 10Zm0-4a6 6 0 1 0-6-6 6 6 0 0 0 6 6Zm0-2a4 4 0 1 1 4-4 4 4 0 0 1-4 4Zm0-2a2 2 0 1 0-2-2 2 2 0 0 0 2 2Z",
  calendar:
    "M19 4h-2V2h-2v2H9V2H7v2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 16H5V9h14Zm0-13H5V6h14Z",
  spark:
    "M12 2 14 9l7 1-5 4 2 8-6-4-6 4 2-8-5-4 7-1Z",
  check:
    "m9 16.2-3.5-3.5a1 1 0 1 0-1.4 1.4l4.2 4.2a1 1 0 0 0 1.4 0L20 7.6a1 1 0 0 0-1.4-1.4Z",
};
---

<div class="flex flex-col items-center text-center">
  <div
    class="inline-flex h-14 w-14 items-center justify-center rounded-full border-2 border-gold-400 bg-cream-50 text-navy-800"
    aria-hidden="true"
  >
    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
      <path d={paths[icon]} />
    </svg>
  </div>
  <h4 class="mt-3 text-sm font-semibold text-navy-800">{title}</h4>
  <p class="mt-1 text-xs text-muted leading-relaxed max-w-[14rem]">{description}</p>
</div>
