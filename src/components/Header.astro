---
import Logo from "./Logo.astro";
import { siteConfig } from "~/lib/siteConfig";
import { link } from "~/lib/url";

const base = (import.meta.env.BASE_URL || "/").replace(/\/$/, "");
const pathname = Astro.url.pathname.replace(new RegExp(`^${base}`), "") || "/";
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(href + "/");
---

<header
  class="sticky top-0 z-50 border-b border-[var(--border-whisper)] bg-paper/95 backdrop-blur supports-[backdrop-filter]:bg-paper/85"
>
  <div class="container-full flex h-16 items-center justify-between gap-3 sm:h-20 sm:gap-8">
    <a href={link("/")} class="min-w-0 shrink" aria-label={`${siteConfig.brand.name} — Ana Sayfa`}>
      <Logo variant="dark" layout="full" class="h-10 w-auto sm:h-12" />
    </a>

    <nav aria-label="Ana navigasyon" class="hidden lg:block">
      <ul class="flex items-center gap-1">
        {
          siteConfig.nav.map((item) => (
            <li class="relative group">
              <a
                href={link(item.href)}
                aria-current={isActive(item.href) ? "page" : undefined}
                class={`inline-flex items-center px-3 py-2 text-[0.8125rem] tracking-wide transition-colors ${
                  isActive(item.href) ? "text-navy-800 font-medium" : "text-ink-secondary hover:text-gold-ink"
                }`}
              >
                {item.label}
                {item.children && (
                  <svg
                    class="ml-1.5 h-2.5 w-2.5 opacity-60"
                    viewBox="0 0 12 12"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                  </svg>
                )}
              </a>
              {item.children && (
                <div class="invisible absolute left-0 top-full z-50 mt-1 w-72 opacity-0 transition-all group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                  <ul class="overflow-hidden rounded-[var(--radius)] bg-paper nm-raised">
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={link(child.href)}
                          class="block px-5 py-3 text-sm text-ink-secondary transition-colors hover:bg-keten hover:text-navy-800"
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="hidden lg:block">
      <a href={link("/iletisim#tanisma")} class="btn btn-primary">Tanışma Görüşmesi</a>
    </div>

    <button
      type="button"
      id="mobile-nav-toggle"
      class="inline-flex h-11 w-11 items-center justify-center rounded-full text-navy-800 nm-raised lg:hidden"
      aria-label="Menüyü aç"
      aria-controls="mobile-nav"
      aria-expanded="false"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-nav"
    class="hidden max-h-[calc(100vh-4rem)] overflow-y-auto border-t border-[var(--border-whisper)] bg-paper lg:hidden"
    aria-hidden="true"
  >
    <nav aria-label="Mobil navigasyon" class="container-full py-5">
      <ul class="flex flex-col gap-1">
        {
          siteConfig.nav.map((item) => (
            <li>
              <a
                href={link(item.href)}
                class="block px-3 py-3 text-base text-navy-800 hover:bg-keten"
              >
                {item.label}
              </a>
              {item.children && (
                <ul class="ml-3 border-l border-[var(--border-soft)] pl-3">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={link(child.href)}
                        class="block px-3 py-2 text-sm text-ink-secondary hover:bg-keten"
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
        <li class="mt-4 pt-4 border-t border-[var(--border-whisper)]">
          <a href={link("/iletisim#tanisma")} class="btn btn-primary w-full">Tanışma Görüşmesi</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-nav-toggle");
  const panel = document.getElementById("mobile-nav");
  if (toggle && panel) {
    toggle.addEventListener("click", () => {
      const open = panel.classList.toggle("hidden");
      const isOpen = !open;
      toggle.setAttribute("aria-expanded", String(isOpen));
      panel.setAttribute("aria-hidden", String(!isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Menüyü kapat" : "Menüyü aç");
    });
  }
</script>
