---
interface Step {
  number: string;
  title: string;
  description: string;
}

interface Props {
  steps?: Step[];
}

const defaultSteps: Step[] = [
  {
    number: "01",
    title: "Tanışma",
    description:
      "Kısa, ücretsiz bir görüşme ile hedeflerinizi, mevcut durumunuzu ve beklentilerinizi dinleriz.",
  },
  {
    number: "02",
    title: "Analiz",
    description:
      "Çalışma alışkanlıkları, zaman yönetimi ve hedefe uzaklık birlikte değerlendirilir.",
  },
  {
    number: "03",
    title: "Plan",
    description:
      "Önceliklendirilmiş, ölçülebilir ve uygulanabilir bir yol haritası birlikte oluşturulur.",
  },
  {
    number: "04",
    title: "Takip",
    description:
      "Düzenli görüşmeler ile süreç izlenir, ihtiyaç olduğunda plan yeniden ayarlanır.",
  },
];

const { steps = defaultSteps } = Astro.props;
---

<ol class="grid gap-10 md:grid-cols-2 lg:grid-cols-4" role="list" data-reveal-group="120">
  {
    steps.map((step) => (
      <li class="border-t border-[var(--border-soft)] pt-6" data-reveal>
        <span
          class="font-[var(--font-italic)] italic text-xl text-gold-ink"
          aria-hidden="true"
        >
          {step.number}
        </span>
        <h3 class="mt-3 text-lg text-navy-800">{step.title}</h3>
        <p class="mt-3 text-sm text-ink-secondary" style="line-height: 1.7;">{step.description}</p>
      </li>
    ))
  }
</ol>
