---
/**
 * Görsel henüz temin edilmediğinde kullanılan, keten zeminli placeholder.
 * Üretime gerçek fotoğraf eklenince bu komponent <img> ile değiştirilir.
 */
interface Props {
  label?: string;
  meta?: string;
  ratio?: "4/5" | "1/1" | "3/4" | "16/9" | "21/9";
  variant?: "keten" | "navy" | "olive";
  class?: string;
}
const {
  label = "Görsel alanı",
  meta = "Burada özgün bir fotoğraf yer alacak",
  ratio = "4/5",
  variant = "keten",
  class: className = "",
} = Astro.props;

const ratioClass = {
  "4/5": "aspect-[4/5]",
  "1/1": "aspect-square",
  "3/4": "aspect-[3/4]",
  "16/9": "aspect-video",
  "21/9": "aspect-[21/9]",
}[ratio];

const variantClass = {
  keten: "bg-keten border-[rgba(20,24,43,0.15)]",
  navy: "bg-navy-800 border-[rgba(247,241,229,0.18)]",
  olive: "bg-olive-600 border-[rgba(247,241,229,0.20)]",
}[variant];

const labelColor = variant === "keten" ? "text-olive-600" : "text-paper";
const metaColor = variant === "keten" ? "text-muted" : "text-paper/70";
---

<figure
  class={`relative flex flex-col items-center justify-center gap-2 overflow-hidden border border-dashed p-8 ${variantClass} ${ratioClass} ${className}`}
  aria-label={label}
>
  <div
    aria-hidden="true"
    class="absolute inset-0 opacity-50"
    style="background-image: linear-gradient(135deg, transparent 0, transparent 49%, currentColor 49%, currentColor 51%, transparent 51%); background-size: 14px 14px; color: rgba(20,24,43,0.06);"
  >
  </div>
  <svg
    width="34"
    height="34"
    viewBox="0 0 24 24"
    fill="none"
    aria-hidden="true"
    class={`relative ${variant === "keten" ? "text-olive-500" : "text-paper/60"}`}
  >
    <rect x="3" y="4" width="18" height="16" stroke="currentColor" stroke-width="1" fill="none" />
    <circle cx="8.5" cy="9.5" r="1.4" stroke="currentColor" stroke-width="1" fill="none" />
    <path d="M21 16l-5-5-4.5 4.5L9 13l-6 6" stroke="currentColor" stroke-width="1" fill="none" />
  </svg>
  <figcaption class={`relative font-[var(--font-italic)] italic text-sm ${labelColor}`}>
    {label}
  </figcaption>
  <p
    class={`relative text-[0.6875rem] uppercase tracking-[0.22em] ${metaColor}`}
    style="font-family: var(--font-sans);"
  >
    {meta}
  </p>
</figure>
