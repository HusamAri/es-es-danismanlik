---
import { Image } from "astro:assets";
import { siteImages, type SiteImageName } from "~/lib/images";

interface Props {
  name: SiteImageName;
  alt: string;
  ratio?: "4/5" | "3/4" | "1/1" | "16/9" | "21/9";
  sizes?: string;
  class?: string;
  loading?: "lazy" | "eager";
  widths?: number[];
}

const {
  name,
  alt,
  ratio = "4/5",
  sizes = "(min-width: 1024px) 40vw, 100vw",
  class: className = "",
  loading = "lazy",
  widths = [480, 768, 1024, 1400],
} = Astro.props;

const src = siteImages[name];
const ratioClass = {
  "4/5": "aspect-[4/5]",
  "3/4": "aspect-[3/4]",
  "1/1": "aspect-square",
  "16/9": "aspect-video",
  "21/9": "aspect-[21/9]",
}[ratio];
---

<div class={`relative overflow-hidden bg-keten ${ratioClass} ${className}`}>
  <Image
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    loading={loading}
    decoding="async"
    class="h-full w-full object-cover"
  />
</div>
