---
interface Props {
  text: string;
  attribution?: string;
  italicWord?: string;
  variant?: "light" | "dark";
}

const { text, attribution, italicWord, variant = "light" } = Astro.props;

let before = text;
let after = "";
if (italicWord && text.includes(italicWord)) {
  const idx = text.indexOf(italicWord);
  before = text.slice(0, idx);
  after = text.slice(idx + italicWord.length);
}

const textColor = variant === "dark" ? "text-paper" : "text-navy-800";
---

<figure class="mx-auto max-w-3xl text-center">
  <hr class={`gold-divider gold-divider-center ${variant === "dark" ? "" : ""}`} style={variant === "dark" ? "background: var(--color-gold-400);" : ""} />
  <blockquote
    class={`font-[var(--font-italic)] italic text-2xl md:text-3xl leading-[1.4] ${textColor}`}
    style="font-weight: 400;"
  >
    {italicWord ? (
      <>
        {before}<span class="accent">{italicWord}</span>{after}
      </>
    ) : text}
  </blockquote>
  {attribution && (
    <figcaption class="mt-6 text-xs uppercase tracking-[0.22em] text-muted" style="font-family: var(--font-sans);">
      {attribution}
    </figcaption>
  )}
</figure>
