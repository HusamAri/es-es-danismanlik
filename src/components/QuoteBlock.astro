---
interface Props {
  text: string;
  attribution?: string;
}

const { text, attribution } = Astro.props;
---

<figure class="relative mx-auto max-w-3xl rounded-3xl border border-gold-200 bg-cream-50 px-8 py-12 text-center md:px-16">
  <span
    aria-hidden="true"
    class="absolute left-6 top-4 font-serif text-6xl leading-none text-gold-400 md:left-10 md:text-7xl"
  >“</span>
  <blockquote class="font-serif text-2xl leading-snug text-navy-800 md:text-3xl">
    {text}
  </blockquote>
  {attribution && (
    <figcaption class="mt-4 text-sm text-muted">{attribution}</figcaption>
  )}
  <span
    aria-hidden="true"
    class="absolute bottom-2 right-6 font-serif text-6xl leading-none text-gold-400 md:right-10 md:text-7xl"
  >”</span>
</figure>
