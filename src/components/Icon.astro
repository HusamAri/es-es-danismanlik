---
/**
 * Marka çizgi-ikon seti (ince stroke, currentColor ile renklenir).
 * Design system: minimal, editorial, altın ince çizgi.
 */
interface Props {
  name:
    | "bireysel"
    | "grup"
    | "kurumsal"
    | "hedef"
    | "takip"
    | "odak"
    | "strateji";
  class?: string;
  size?: number;
}
const { name, class: className = "", size = 40 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 40 40"
  fill="none"
  stroke="currentColor"
  stroke-width="1.4"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  role="img"
  aria-hidden="true"
>
  {/* Bireysel — öğrenciden hedefe uzanan rehberlik yolu */}
  {name === "bireysel" && (
    <>
      <circle cx="8.5" cy="31.5" r="2.1" fill="currentColor" stroke="none" />
      <path d="M9 30 C 17 28, 21 18, 30.5 13.8" stroke-dasharray="0.1 3.2" />
      <circle cx="31" cy="11" r="3.6" />
    </>
  )}

  {/* Grup — üç düğüm, ince bağlarla */}
  {name === "grup" && (
    <>
      <circle cx="20" cy="10" r="3" />
      <circle cx="10" cy="28" r="3" />
      <circle cx="30" cy="28" r="3" />
      <path d="M18.4 12.6 L11.6 25.4" />
      <path d="M21.6 12.6 L28.4 25.4" />
      <path d="M13 28 L27 28" />
    </>
  )}

  {/* Kurumsal — akademik bina (alınlık + sütunlar) */}
  {name === "kurumsal" && (
    <>
      <path d="M6 17 L20 8.5 L34 17" />
      <line x1="9" y1="18" x2="9" y2="28.5" />
      <line x1="16.3" y1="18" x2="16.3" y2="28.5" />
      <line x1="23.6" y1="18" x2="23.6" y2="28.5" />
      <line x1="31" y1="18" x2="31" y2="28.5" />
      <line x1="5" y1="31" x2="35" y2="31" />
    </>
  )}

  {/* Hedef */}
  {name === "hedef" && (
    <>
      <circle cx="20" cy="20" r="12" />
      <circle cx="20" cy="20" r="6.5" />
      <circle cx="20" cy="20" r="1.6" fill="currentColor" stroke="none" />
    </>
  )}

  {/* Düzenli takip — döngü/yenileme */}
  {name === "takip" && (
    <>
      <path d="M31 16 A 12 12 0 1 0 32 24" />
      <path d="M31 9 L31 16 L24 16" />
    </>
  )}

  {/* Motivasyon ve odak — pusula */}
  {name === "odak" && (
    <>
      <circle cx="20" cy="20" r="12.5" />
      <path d="M25.5 14.5 L18 18 L14.5 25.5 L22 22 Z" />
    </>
  )}

  {/* Strateji — satranç ucu / yön */}
  {name === "strateji" && (
    <>
      <path d="M10 30 L20 9 L30 30" />
      <path d="M14 22 L26 22" />
    </>
  )}
</svg>
