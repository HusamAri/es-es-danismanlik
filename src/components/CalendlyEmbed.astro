---
import { siteConfig } from "~/lib/siteConfig";

interface Props {
  url?: string;
  height?: number;
}

const { url = siteConfig.calendly.introUrl, height = 700 } = Astro.props;
const enabled = siteConfig.calendly.enabled;
---

{
  enabled ? (
    <div class="border border-[var(--border-soft)] bg-paper p-2">
      <iframe
        src={url}
        loading="lazy"
        title="Tanışma görüşmesi takvimi"
        width="100%"
        height={String(height)}
        class="block w-full bg-paper"
      />
    </div>
  ) : (
    <div class="border border-dashed border-[var(--border-soft)] bg-keten p-12 text-center">
      <span class="eyebrow">Yakında</span>
      <h3 class="mt-3">Online randevu</h3>
      <hr class="gold-divider gold-divider-center" />
      <p class="text-sm text-ink-secondary" style="line-height: 1.7;">
        Online randevu sistemi yakında bu sayfada yer alacak. Şimdilik aşağıdaki form, telefon
        veya WhatsApp ile bize ulaşabilirsiniz.
      </p>
      <div class="mt-8 flex justify-center gap-3">
        <a href={`tel:${siteConfig.contact.phoneE164}`} class="btn btn-primary">
          {siteConfig.contact.phone}
        </a>
      </div>
    </div>
  )
}
