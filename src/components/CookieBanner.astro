---
import { link } from "~/lib/url";
---

<div
  id="cookie-banner"
  hidden
  class="fixed inset-x-0 bottom-0 z-50 rounded-t-[var(--radius-lg)] bg-paper shadow-[0_-12px_40px_-12px_rgba(94,74,38,0.28)]"
  role="region"
  aria-label="Çerez tercihleri"
>
  <div class="container-wide flex flex-col gap-4 py-5 md:flex-row md:items-center md:justify-between">
    <p class="max-w-2xl text-sm text-ink-secondary" style="line-height: 1.6;">
      Bu sitede yalnızca işlevsel ve isteğe bağlı analitik çerezler kullanıyoruz. Detaylar için
      <a href={link("/cerez-politikasi")} class="text-navy-800 underline decoration-gold-500 underline-offset-4">Çerez Politikası</a>
      sayfasını inceleyebilirsiniz.
    </p>
    <div class="flex items-center gap-3">
      <button type="button" id="cookie-reject" class="btn btn-secondary">
        Sadece zorunlu
      </button>
      <button type="button" id="cookie-accept" class="btn btn-primary">
        Tümünü kabul et
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = "es_es_cookie_consent_v1";
    var banner = document.getElementById("cookie-banner");
    var accept = document.getElementById("cookie-accept");
    var reject = document.getElementById("cookie-reject");
    if (!banner || !accept || !reject) return;

    function setConsent(value) {
      try {
        localStorage.setItem(KEY, JSON.stringify({ choice: value, ts: Date.now() }));
      } catch (e) {}
      banner.hidden = true;
      document.documentElement.setAttribute("data-consent", value);
      if (value === "all") {
        document.dispatchEvent(new CustomEvent("consent:granted"));
      }
    }

    var existing = null;
    try {
      existing = JSON.parse(localStorage.getItem(KEY) || "null");
    } catch (e) {}

    if (!existing) {
      banner.hidden = false;
    } else {
      document.documentElement.setAttribute("data-consent", existing.choice);
      if (existing.choice === "all") {
        document.dispatchEvent(new CustomEvent("consent:granted"));
      }
    }

    accept.addEventListener("click", function () { setConsent("all"); });
    reject.addEventListener("click", function () { setConsent("necessary"); });
  })();
</script>
