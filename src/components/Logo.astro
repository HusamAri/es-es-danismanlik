---
import { link } from "~/lib/url";

interface Props {
  /** light = beyaz/krem logoyu (koyu zeminler için), dark = lacivert/siyah logoyu (açık zeminler için) */
  variant?: "dark" | "light";
  /** "full" = ES-ES + DANIŞMANLIK yatay set. "mark" = sadece ES-ES monogramı. */
  layout?: "full" | "mark";
  class?: string;
  title?: string;
}

const {
  variant = "dark",
  layout = "full",
  class: className = "",
  title = "ES-ES Danışmanlık",
} = Astro.props;

const file =
  layout === "mark"
    ? variant === "dark"
      ? "/logo-mark-dark.svg"
      : "/logo-mark-light.svg"
    : variant === "dark"
      ? "/logo-dark.svg"
      : "/logo-light.svg";

const src = link(file);
---

<img
  src={src}
  alt={title}
  class={`block ${className}`}
  loading="eager"
  decoding="async"
/>
