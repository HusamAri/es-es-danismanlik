---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProcessSteps from "~/components/ProcessSteps.astro";
import CTASection from "~/components/CTASection.astro";
import QuoteBlock from "~/components/QuoteBlock.astro";
---

<BaseLayout
  title="Yaklaşımımız"
  description="Süreç odaklı, şeffaf ve ölçülebilir; ES-ES Danışmanlık'ın bireysel ve kurumsal danışmanlıkta uyguladığı yöntem ve çalışma ilkeleri."
>
  <section class="bg-navy-800 py-20 text-white">
    <div class="container-wide">
      <span class="eyebrow text-gold-300">Yaklaşımımız</span>
      <h1 class="mt-2 text-white">Etkili Süreç, Etkili Sonuç.</h1>
      <hr class="gold-divider" />
      <p class="max-w-2xl text-cream-100/85 md:text-lg">
        Bizim için hizmet, görüşmelerden ibaret değildir. Hedeften tasarıma, tasarımdan uygulamaya
        ve raporlamaya kadar uçtan uca tasarlanmış bir süreçtir.
      </p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="container-wide grid gap-12 md:grid-cols-12">
      <div class="md:col-span-7">
        <h2>İlkelerimiz</h2>
        <hr class="gold-divider" />
        <div class="prose-tr">
          <h3>1. Şeffaflık</h3>
          <p>
            Sürecin başında neyi nasıl çalışacağımızı net olarak paylaşırız. Vaatlerimiz ölçülebilir
            olur; kesin sonuç garantisi vermeyiz.
          </p>
          <h3>2. Süreklilik</h3>
          <p>
            Tek seferlik müdahalelerin yerine, küçük ama sürdürülebilir adımlara inanırız. Düzenli
            görüşmeler ve periyodik gözden geçirmeler temel ritmimizdir.
          </p>
          <h3>3. Bireysellik</h3>
          <p>
            Hazır şablonlar dayatmıyoruz; her öğrencinin ve her kurumun ihtiyacı farklıdır. Süreç
            ortak tasarlanır.
          </p>
          <h3>4. Etik ve Gizlilik</h3>
          <p>
            Görüşme içerikleri, öğrenci bilgileri ve kurumsal veriler KVKK uyumlu biçimde işlenir.
            İsim, fotoğraf, kurum adı yazılı izin olmadan paylaşılmaz.
          </p>
          <h3>5. Ölçülebilirlik</h3>
          <p>
            Sürecin başında belirlediğimiz hedefleri belirli aralıklarla gözden geçirir; gerekirse
            planı revize ederiz. Karar, hisse değil veriye dayanır.
          </p>
        </div>
      </div>

      <aside class="md:col-span-5">
        <div class="card-dark sticky top-28">
          <h3 class="text-white">Kullandığımız Araçlar</h3>
          <hr class="gold-divider" />
          <ul class="space-y-2 text-sm text-cream-100/90">
            <li>● Haftalık ilerleme formları</li>
            <li>● Kişiye özel hedef takip tabloları</li>
            <li>● Online görüşme platformları (Meet, Zoom)</li>
            <li>● Anonim dönem değerlendirme anketleri</li>
            <li>● Kurumsal süreç raporları</li>
          </ul>
          <p class="mt-4 text-xs text-cream-200/65">
            Tüm araç ve veriler KVKK'ya uygun saklanır ve hizmet sonunda imha edilir veya
            anonimleştirilir.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <section class="bg-cream-50 py-20">
    <div class="container-wide">
      <h2 class="text-center">Çalışma Sürecimiz</h2>
      <hr class="gold-divider mx-auto" />
      <div class="mt-10">
        <ProcessSteps />
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="container-wide">
      <QuoteBlock text="Doğru rehberlik, etkili süreçle birleştiğinde etkili sonuçlar doğurur." />
    </div>
  </section>

  <CTASection />
</BaseLayout>
