---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { link } from "~/lib/url";
---

<BaseLayout
  title="Sayfa Bulunamadı"
  description="Aradığınız sayfa bulunamadı."
  noindex={true}
>
  <section class="bg-paper">
    <div class="container-wide py-32 text-center">
      <span class="eyebrow">404</span>
      <h1 class="mt-6 text-display">
        Bu sayfa<br /><span class="accent">bulunamadı.</span>
      </h1>
      <hr class="gold-divider gold-divider-center" />
      <p class="mx-auto max-w-xl text-lead text-ink-secondary" style="line-height: 1.7;">
        Aradığınız sayfa taşınmış, kaldırılmış veya hiç var olmamış olabilir.
      </p>
      <div class="mt-10 flex justify-center gap-3">
        <a href={link("/")} class="btn btn-primary">Ana Sayfaya Dön</a>
        <a href={link("/iletisim")} class="btn btn-secondary">İletişime Geç</a>
      </div>
    </div>
  </section>
</BaseLayout>
