---
import BaseLayout from "~/layouts/BaseLayout.astro";
import FAQ from "~/components/FAQ.astro";
import CTASection from "~/components/CTASection.astro";
import { getCollection } from "astro:content";

const all = (await getCollection("faq")).sort((a, b) => a.data.order - b.data.order);
const items = all.map((entry) => entry.data);

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<BaseLayout
  title="Sıkça Sorulan Sorular"
  description="ES-ES Danışmanlık hizmetleri, fiyatlandırma, format, KVKK ve kurumsal danışmanlık hakkında en sık sorulan soruların cevapları."
  jsonLd={faqJsonLd}
>
  <section class="bg-paper">
    <div class="container-wide py-24 md:py-32">
      <span class="eyebrow">SSS</span>
      <h1 class="mt-6 text-display max-w-3xl">
        Sıkça sorulan<br /><span class="accent">sorular.</span>
      </h1>
      <hr class="gold-divider" />
      <p class="mt-6 max-w-2xl text-lead text-ink-secondary" style="line-height: 1.7;">
        Hizmetlerimizle ilgili en sık sorulan soruları aşağıda toparladık. Aradığınız cevabı
        bulamazsanız iletişim formundan veya WhatsApp üzerinden ulaşabilirsiniz.
      </p>
    </div>
  </section>

  <section class="bg-keten">
    <div class="container-wide py-24 md:py-32">
      <FAQ items={items} />
    </div>
  </section>

  <CTASection />
</BaseLayout>
