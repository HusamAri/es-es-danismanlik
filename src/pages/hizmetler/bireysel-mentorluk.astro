---
import BaseLayout from "~/layouts/BaseLayout.astro";
import CTASection from "~/components/CTASection.astro";
import ProcessSteps from "~/components/ProcessSteps.astro";
import SectionHeading from "~/components/SectionHeading.astro";
import SiteImage from "~/components/SiteImage.astro";
import { link } from "~/lib/url";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Bireysel Akademik Mentörlük",
  provider: { "@type": "Organization", name: "ES-ES Danışmanlık" },
  areaServed: "TR",
  audience: { "@type": "EducationalAudience", educationalRole: "student" },
};
---

<BaseLayout
  title="Bireysel Akademik Mentörlük"
  description="Öğrencinin hedeflerine, çalışma stiline ve önceliklerine uygun olarak tasarlanan, düzenli takip ve kişiselleştirilmiş plana dayalı birebir mentörlük."
  jsonLd={jsonLd}
>
  <section class="bg-paper">
    <div class="container-wide py-24 md:py-32 grid gap-12 md:grid-cols-12">
      <div class="md:col-span-8">
        <span class="eyebrow" data-reveal="fade">Hizmet · 01</span>
        <h1 class="mt-6 text-display" data-reveal style="--reveal-delay: 120ms;">
          Bireysel<br /><span class="accent">akademik mentörlük.</span>
        </h1>
        <hr class="gold-divider" />
        <p class="mt-6 max-w-2xl text-lead text-ink-secondary" style="line-height: 1.7;">
          Her öğrencinin hedefi, çalışma stili ve gündemi farklıdır. Bireysel mentörlük; standart
          bir takvim dayatmak yerine, öğrencinin yaşamına uyum sağlayan ve sonucu sürece dönüştüren
          bir destek modelidir.
        </p>
        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <a href={link("/iletisim?konu=bireysel")} class="btn btn-primary">Tanışma Görüşmesi</a>
          <a href={link("/yaklasimimiz")} class="btn btn-secondary">Yaklaşımımız</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-keten">
    <div class="container-wide py-24 md:py-32 grid gap-16 md:grid-cols-12">
      <div class="md:col-span-7">
        <h2>Kimler için?</h2>
        <hr class="gold-divider" />
        <ul class="space-y-4 text-base text-ink-secondary">
          <li class="flex items-baseline gap-4">
            <span class="font-[var(--font-italic)] italic text-gold-ink shrink-0">·</span>
            Lise dönemindeki öğrenciler
          </li>
          <li class="flex items-baseline gap-4">
            <span class="font-[var(--font-italic)] italic text-gold-ink shrink-0">·</span>
            Üniversite sınavına hazırlanan öğrenciler
          </li>
          <li class="flex items-baseline gap-4">
            <span class="font-[var(--font-italic)] italic text-gold-ink shrink-0">·</span>
            Üniversite öğrencileri (bölüm, kariyer, süreç yönetimi)
          </li>
          <li class="flex items-baseline gap-4">
            <span class="font-[var(--font-italic)] italic text-gold-ink shrink-0">·</span>
            Veliyle birlikte takip edilmek istenen orta-lise süreçleri
          </li>
        </ul>

        <h2 class="mt-16">Hangi konularda?</h2>
        <hr class="gold-divider" />
        <div class="grid gap-8 md:grid-cols-2">
          {[
            ["Çalışma stratejisi", "Verimli, sürdürülebilir çalışma yöntemleri."],
            ["Zaman ve odak yönetimi", "Dikkat dağıtıcılarla başa çıkma, ritim kurma."],
            ["Hedef belirleme", "Net, ölçülebilir ve gerçekçi hedef tasarımı."],
            ["Sınav süreç planlama", "Aylık-haftalık-günlük plan ve revizyonlar."],
            ["Motivasyon ve süreklilik", "Düşüş dönemlerinde toparlanma stratejileri."],
            ["Kariyer ve tercih süreci", "Bölüm, üniversite ve yön seçim danışmanlığı."],
          ].map(([t, d]) => (
            <div class="card">
              <h3 class="text-base text-navy-800">{t}</h3>
              <p class="mt-2 text-sm text-ink-secondary" style="line-height: 1.7;">{d}</p>
            </div>
          ))}
        </div>
        <p class="mt-8 text-xs text-muted" style="font-family: var(--font-sans); letter-spacing: 0.04em;">
          Çalışma ortağı ve mentör olarak süreci birlikte yönetir, öğrencinin kendi ritmini
          bulmasına rehberlik ederiz.
        </p>
      </div>

      <aside class="md:col-span-5">
        <div class="sticky top-28 space-y-8">
          <SiteImage
            name="bireysel"
            alt="Pencere kenarında birebir mentörlük görüşmesi"
            ratio="3/4"
            sizes="(min-width: 768px) 40vw, 90vw"
           class="img-zoom" />
          <div class="card-navy">
            <h3 class="text-paper" style="color: var(--color-paper);">Program detayları</h3>
            <hr class="gold-divider" style="background: var(--color-gold-400);" />
            <dl class="space-y-4 text-sm text-paper/85">
              <div>
                <dt class="text-xs uppercase tracking-[0.22em] text-paper/55" style="font-family: var(--font-sans);">Format</dt>
                <dd class="mt-1">Online (Meet/Zoom) veya randevulu yüz yüze</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-[0.22em] text-paper/55" style="font-family: var(--font-sans);">Süre</dt>
                <dd class="mt-1">30-60 dakika / haftalık</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-[0.22em] text-paper/55" style="font-family: var(--font-sans);">Periyot</dt>
                <dd class="mt-1">3 ay (dönemlik) veya yıl boyu</dd>
              </div>
              <div>
                <dt class="text-xs uppercase tracking-[0.22em] text-paper/55" style="font-family: var(--font-sans);">İlk Görüşme</dt>
                <dd class="mt-1">Ücretsiz, bağlayıcı değil</dd>
              </div>
            </dl>
            <a
              href={link("/iletisim?konu=bireysel")}
              class="btn mt-8 w-full"
              style="background: var(--color-gold-500); color: var(--color-navy-900); border-color: var(--color-gold-500);"
            >
              Görüşme Talep Et
            </a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="bg-paper">
    <div class="container-wide py-24 md:py-32">
      <SectionHeading
        eyebrow="Süreç"
        title="Bireysel mentörlük"
        italicTail="akışı."
      />
      <div class="mt-16">
        <ProcessSteps />
      </div>
    </div>
  </section>

  <CTASection
    title="Birlikte planlı,"
    italicTail="izlenebilir bir süreç."
    description="Önce dinleyelim, sonra birlikte hedefleri belirleyelim. İlk görüşme her zaman ücretsiz."
  />
</BaseLayout>
