---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SectionHeading from "~/components/SectionHeading.astro";
import ServiceCard from "~/components/ServiceCard.astro";
import CTASection from "~/components/CTASection.astro";
import { link } from "~/lib/url";
---

<BaseLayout
  title="Hizmetlerimiz"
  description="Bireysel akademik mentörlük, grup mentörlük programları ve okullara yönelik kurumsal danışmanlık."
>
  <section class="bg-paper">
    <div class="container-wide py-24 md:py-32">
      <span class="eyebrow" data-reveal="fade">Hizmetler</span>
      <h1 class="mt-6 text-display max-w-3xl" data-reveal style="--reveal-delay: 120ms;">
        Hangi alanda<br /><span class="accent">destek olabiliriz?</span>
      </h1>
      <hr class="gold-divider" />
      <p class="mt-6 max-w-2xl text-lead text-ink-secondary" style="line-height: 1.7;">
        Bireysel öğrencilerden okullara kadar farklı ölçeklerde danışmanlık ve mentörlük sunuyoruz.
        Aşağıdaki üç hizmet, ihtiyacınıza göre kişiselleştirilebilir.
      </p>
    </div>
  </section>

  <section class="bg-keten">
    <div class="container-wide py-24 md:py-32">
      <div class="grid gap-12 md:grid-cols-3 md:gap-10">
        <ServiceCard
          index="01"
          title="Bireysel Akademik Mentörlük"
          description="Öğrenciye özel hedef belirleme, planlama, motivasyon takibi ve düzenli geri bildirim odaklı birebir mentörlük programı."
          href={link("/hizmetler/bireysel-mentorluk")}
        />
        <ServiceCard
          index="02"
          title="Grup Mentörlük Programları"
          description="Sınırlı kontenjanlı, modüler temalarla işlenen, akran etkileşimi ve ortak hedef oluşturmaya dayalı grup süreci."
          href={link("/hizmetler/grup-programlari")}
        />
        <ServiceCard
          index="03"
          title="Kurumsal Danışmanlık"
          description="Okul ve eğitim kurumları için öğretmen gelişimi, rehberlik birimi danışmanlığı ve süreç tasarımı."
          href={link("/hizmetler/kurumsal")}
        />
      </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="container-wide py-24 md:py-32">
      <SectionHeading
        eyebrow="Odağımız"
        title="Süreç, strateji"
        italicTail="ve sürdürülebilirlik."
        description="Hizmetlerimiz; çalışma stratejisi, zaman ve odak yönetimi, hedef belirleme, sınav süreç planlaması, motivasyon takibi ve kariyer-tercih süreçlerine rehberlik gibi danışmanlık ve mentörlük başlıklarından oluşur."
      />
    </div>
  </section>

  <CTASection />
</BaseLayout>
