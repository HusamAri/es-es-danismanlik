---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Hero from "~/components/Hero.astro";
import SectionHeading from "~/components/SectionHeading.astro";
import ServiceCard from "~/components/ServiceCard.astro";
import ValueBadge from "~/components/ValueBadge.astro";
import ProcessSteps from "~/components/ProcessSteps.astro";
import QuoteBlock from "~/components/QuoteBlock.astro";
import FAQ from "~/components/FAQ.astro";
import CTASection from "~/components/CTASection.astro";
import ImagePlaceholder from "~/components/ImagePlaceholder.astro";
import { getCollection } from "astro:content";
import { link } from "~/lib/url";

const faqs = (await getCollection("faq"))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 5)
  .map((entry) => entry.data);

const homeJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "ES-ES Danışmanlık",
  url: "https://esesdanismanlik.net",
  areaServed: "TR",
  serviceType: [
    "Bireysel Akademik Mentörlük",
    "Grup Mentörlük Programları",
    "Kurumsal Eğitim Danışmanlığı",
  ],
  slogan: "Hedefe giden yolun sessiz rehberi.",
};
---

<BaseLayout
  title="ES-ES Danışmanlık — Hedefe giden yolun sessiz rehberi"
  description="ES-ES Danışmanlık; öğrencilere bireysel akademik mentörlük, grup programları ve okullara yönelik kurumsal eğitim danışmanlığı sunar. Süreç odaklı, sessiz ve ölçülü."
  jsonLd={homeJsonLd}
>
  <Hero />

  <section class="bg-keten">
    <div class="container-wide py-24 md:py-32">
      <SectionHeading
        eyebrow="Hizmetler"
        title="Üç başlık,"
        italicTail="tek bir disiplin."
        description="Bireysel öğrenciden okul kadrosuna; her ölçekte aynı yöntemle çalışıyoruz: süreç, plan, takip."
      />
      <div class="mt-20 grid gap-12 md:grid-cols-3 md:gap-10">
        <ServiceCard
          index="01"
          title="Bireysel Akademik Mentörlük"
          description="Öğrencinin hedefine, çalışma stiline ve önceliklerine göre tasarlanan birebir program; düzenli görüşme ve geri bildirim ile sürdürülür."
          href={link("/hizmetler/bireysel-mentorluk")}
        />
        <ServiceCard
          index="02"
          title="Grup Mentörlük Programları"
          description="Sınırlı kontenjanlı, modüler temalarla işlenen, akran etkileşimini güçlü bir disiplinle birleştiren süreçler."
          href={link("/hizmetler/grup-programlari")}
        />
        <ServiceCard
          index="03"
          title="Kurumsal Danışmanlık"
          description="Okullar ve eğitim kurumları için öğretmen gelişimi, rehberlik birimi danışmanlığı, süreç ve müfredat tasarımı."
          href={link("/hizmetler/kurumsal")}
        />
      </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="container-wide py-24 md:py-32">
      <div class="grid gap-12 md:grid-cols-12">
        <div class="md:col-span-5">
          <SectionHeading
            align="left"
            eyebrow="Yaklaşım"
            title="Sessiz bir disiplin,"
            italicTail="görünmez bir çerçeve."
            description="Sürecin merkezinde standart bir program değil; öğrencinin ya da kurumun gerçek hayatına uyum sağlayan bir çerçeve var."
          />
        </div>
        <div class="grid grid-cols-2 gap-10 md:col-span-7 md:grid-cols-2">
          <ValueBadge
            number="i."
            title="Hedef ve plan"
            description="Net, gerçekçi ve ölçülebilir hedefler ile yazılı bir yol haritası."
          />
          <ValueBadge
            number="ii."
            title="Düzenli takip"
            description="Süreklilik ve geri bildirim ile sürdürülebilir ilerleme."
          />
          <ValueBadge
            number="iii."
            title="Motivasyon ve odak"
            description="Dikkat dağıtıcıları yönetmek için pratik stratejiler."
          />
          <ValueBadge
            number="iv."
            title="Doğru strateji"
            description="Verimli çalışmayı sonuca dönüştüren rafine yöntemler."
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="container-wide pb-24 md:pb-32">
      <SectionHeading
        eyebrow="Süreç"
        title="Dört adımda"
        italicTail="ortak ritim."
      />
      <div class="mt-16">
        <ProcessSteps />
      </div>
    </div>
  </section>

  <section class="bg-navy-800 text-paper">
    <div class="container-wide py-24 md:py-28">
      <QuoteBlock
        text="Doğru rehberlik, etkili süreçle birleştiğinde etkili sonuçlar doğurur."
        italicWord="etkili sonuçlar"
        variant="dark"
      />
    </div>
  </section>

  <section class="bg-paper">
    <div class="container-wide py-24 md:py-32">
      <div class="grid items-start gap-16 md:grid-cols-12">
        <div class="md:col-span-6">
          <span class="eyebrow">Kurumlar İçin</span>
          <h2 class="mt-3">
            Okullarla<br /><span class="accent">birlikte düşünmek.</span>
          </h2>
          <hr class="gold-divider" />
          <p class="text-lead text-ink-secondary" style="line-height: 1.7;">
            Öğretmen kadrosunun mesleki gelişiminden rehberlik biriminin etkinliğine, müfredat
            dışı tasarımdan veli iletişim modellerine kadar uçtan uca danışmanlık.
          </p>
          <ul class="mt-8 space-y-4 text-sm text-ink-secondary">
            <li class="flex items-baseline gap-4">
              <span class="font-[var(--font-italic)] italic text-gold-500 text-base shrink-0">·</span>
              Öğretmen mesleki gelişim atölyeleri
            </li>
            <li class="flex items-baseline gap-4">
              <span class="font-[var(--font-italic)] italic text-gold-500 text-base shrink-0">·</span>
              Rehberlik birimi danışmanlığı
            </li>
            <li class="flex items-baseline gap-4">
              <span class="font-[var(--font-italic)] italic text-gold-500 text-base shrink-0">·</span>
              Veli bilgilendirme seminerleri
            </li>
            <li class="flex items-baseline gap-4">
              <span class="font-[var(--font-italic)] italic text-gold-500 text-base shrink-0">·</span>
              Süreç ve ölçme-değerlendirme tasarımı
            </li>
          </ul>
          <div class="mt-10 flex flex-col gap-3 sm:flex-row">
            <a href={link("/hizmetler/kurumsal")} class="btn btn-primary">Kurumsal Çözümler</a>
            <a href={link("/iletisim?konu=kurumsal")} class="btn btn-secondary">Teklif Talep Et</a>
          </div>
        </div>
        <div class="md:col-span-6">
          <ImagePlaceholder
            label="Okul ortamında çalışan ekip"
            meta="Atölye · doğal ışık · 1:1"
            ratio="1/1"
            variant="olive"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-keten">
    <div class="container-wide py-24 md:py-32">
      <SectionHeading
        eyebrow="Merak Edilenler"
        title="Sıkça sorulan"
        italicTail="sorular."
        description="Aklınızdaki ilk soruların kısa cevapları. Tüm liste için SSS sayfamızı görüntüleyebilirsiniz."
      />
      <div class="mt-16">
        <FAQ items={faqs} />
      </div>
      <div class="mt-12 text-center">
        <a href={link("/sss")} class="btn btn-secondary">Tüm Soruları Gör</a>
      </div>
    </div>
  </section>

  <CTASection
    title="Tanışalım."
    italicTail="Önce dinleyelim."
    description="Ücretsiz tanışma görüşmesinde önceliklerinizi konuşalım; size en uygun yaklaşımı birlikte belirleyelim."
    primaryLabel="Tanışma Görüşmesi"
    secondaryLabel="Hizmetleri İncele"
  />
</BaseLayout>
